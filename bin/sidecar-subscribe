#!/bin/bash
set -euo pipefail

show_help() {
  cat <<'EOF'
usage: sidecar-subscribe (--url URL | --file FILE) [--list] [--index N | --keyword KEYWORD | --all-nodes] [--restart]

Generate or update Mihomo config.yaml from a subscription source.
EOF
}

if [[ $# -gt 0 && ( "$1" == "-h" || "$1" == "--help" ) ]]; then
  show_help
  exit 0
fi

BIN_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
SIDECAR_ROOT=$(cd -- "${BIN_DIR}/.." && pwd -P)
export MIHOMO_HOME="${MIHOMO_HOME:-${SIDECAR_ROOT}}"
export MIHOMO_SIDECAR_CONFIG="${MIHOMO_SIDECAR_CONFIG:-${SIDECAR_ROOT}/sidecar.env}"
if [[ -f "${BIN_DIR}/../script/common.sh" ]]; then
  # shellcheck disable=SC1091
  source "${BIN_DIR}/../script/common.sh"
elif [[ -f "${BIN_DIR}/../common.sh" ]]; then
  # shellcheck disable=SC1091
  source "${BIN_DIR}/../common.sh"
else
  echo "common.sh not found" >&2
  exit 1
fi

sidecar_load_config

subscription_url=""
subscription_file=""
restart_service=0
list_only=0
passthrough=()

die() {
  echo "$*" >&2
  exit 1
}

current_username() {
  id -un 2>/dev/null || printf 'uid-%s\n' "$(id -u)"
}

ensure_group_member() {
  if [[ ${EUID:-$(id -u)} -eq 0 ]]; then
    return 0
  fi
  if id -nG 2>/dev/null | tr ' ' '\n' | grep -Fxq "${MIHOMO_SIDECAR_GROUP}"; then
    return 0
  fi
  die "current user is not in group ${MIHOMO_SIDECAR_GROUP}. Ask the administrator to run: sudo usermod -aG ${MIHOMO_SIDECAR_GROUP} <your-user>"
}

require_readable_file() {
  local path=$1 label=$2
  [[ -f "${path}" ]] || die "${label} not found: ${path}. Please rerun: sudo ./install.sh"
  [[ -r "${path}" ]] || die "${label} is not readable: ${path}. Check group ${MIHOMO_SIDECAR_GROUP} permissions."
}

require_writable_file() {
  local path=$1 label=$2
  [[ -f "${path}" ]] || die "${label} not found: ${path}. Please rerun: sudo ./install.sh"
  [[ -w "${path}" ]] || die "${label} is not writable: ${path}. Check group ${MIHOMO_SIDECAR_GROUP} permissions."
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --url)
      subscription_url=$2
      shift 2
      ;;
    --file)
      subscription_file=$2
      shift 2
      ;;
    --index)
      passthrough+=("--select-index" "$2")
      shift 2
      ;;
    --keyword)
      passthrough+=("--select-keyword" "$2")
      shift 2
      ;;
    --restart)
      restart_service=1
      shift
      ;;
    --list)
      list_only=1
      passthrough+=("$1")
      shift
      ;;
    *)
      passthrough+=("$1")
      shift
      ;;
  esac
done

if [[ -n "${subscription_url}" && -n "${subscription_file}" ]]; then
  echo "please use only one of --url or --file" >&2
  exit 2
fi

if [[ -z "${subscription_url}" && -z "${subscription_file}" ]]; then
  show_help >&2
  exit 2
fi

ensure_group_member
require_readable_file "${MIHOMO_SECRET_FILE}" "controller secret"
require_writable_file "${MIHOMO_CONFIG_YAML}" "config.yaml"

user_sub_dir="${MIHOMO_HOME}/sub/$(current_username)"
mkdir -p "${user_sub_dir}" || die "cannot create subscription cache dir: ${user_sub_dir}. Check ${MIHOMO_HOME}/sub permissions."
[[ -w "${user_sub_dir}" ]] || die "subscription cache dir is not writable: ${user_sub_dir}. Check ${MIHOMO_HOME}/sub permissions."
chmod 0700 "${user_sub_dir}" 2>/dev/null || true

controller_secret=$(tr -d '\r\n' < "${MIHOMO_SECRET_FILE}")
subscription_source="${subscription_url:-${subscription_file}}"
sub_args=(
  --source "${subscription_source}"
  --output "${MIHOMO_CONFIG_YAML}"
  --secret "${controller_secret}"
  --save-raw-dir "${user_sub_dir}"
)
if [[ ${#passthrough[@]} -gt 0 ]]; then
  sub_args+=("${passthrough[@]}")
fi

if [[ ${list_only} -eq 1 ]]; then
  echo "Available nodes:"
  echo
  MIHOMO_SIDECAR_CONFIG="${MIHOMO_HOME}/sidecar.env" \
    python3 "${SIDECAR_ROOT}/sub2mihomo.py" "${sub_args[@]}"
  exit 0
fi

summary_json=$(
  MIHOMO_SIDECAR_CONFIG="${MIHOMO_HOME}/sidecar.env" \
    python3 "${SIDECAR_ROOT}/sub2mihomo.py" \
      "${sub_args[@]}" \
      --summary-json
)

service_state="unknown"
service_known=0
service_enabled=0
if command -v systemctl >/dev/null 2>&1; then
  if systemctl status "${MIHOMO_SERVICE_NAME}" >/dev/null 2>&1; then
    service_known=1
  fi
  if systemctl is-active --quiet "${MIHOMO_SERVICE_NAME}" 2>/dev/null; then
    service_state="active"
  elif [[ ${service_known} -eq 1 ]]; then
    service_state="inactive"
  fi
  if systemctl is-enabled --quiet "${MIHOMO_SERVICE_NAME}" 2>/dev/null; then
    service_enabled=1
  fi
fi

python3 - "${summary_json}" "${MIHOMO_HOME}" "${MIHOMO_SERVICE_NAME}" "${service_state}" "${service_known}" "${service_enabled}" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
work_dir = sys.argv[2]
service_name = sys.argv[3]
service_state = sys.argv[4]
service_known = sys.argv[5] == "1"
service_enabled = sys.argv[6] == "1"

print("Subscription updated.")
print()
print("Work dir:")
print(f"  {work_dir}")
print()
print("Generated:")
print(f"  config.yaml         {summary['output']}")
print(f"  raw subscription    {summary['raw_output']}")
print(f"  decoded subscription {summary['decoded_output']}")
print(f"  controller secret   {work_dir}/state/controller.secret (reused)")
print()
print("Node summary:")
print(f"  total nodes         {summary['total_nodes']}")
print(f"  written nodes       {summary['written_nodes']}")
print(f"  proxy group         {summary['proxy_group']}")
if summary["selection_mode"] == "all":
    print("  selection           all nodes written to config")
else:
    selected = summary.get("selected_names") or []
    current = selected[0] if selected else "-"
    print(f"  selection           single node: {current}")
print()
print("Service:")
if service_state == "active":
    print(f"  status              running ({service_name})")
elif service_known:
    suffix = "enabled" if service_enabled else "not enabled"
    print(f"  status              installed but not running ({suffix})")
else:
    print(f"  status              unit state unknown ({service_name})")
print()
print("Next steps:")
if service_state == "active":
    print(f"  1. Reload config: sudo systemctl restart {service_name}")
    print("  2. Check current node: sidecar-node --current")
    print("  3. Verify installation: sudo sidecar-verify")
else:
    print("  1. Reload systemd: sudo systemctl daemon-reload")
    print(f"  2. Start service: sudo systemctl enable --now {service_name}")
    print("  3. Check current node: sidecar-node --current")
    print("  4. Verify installation: sudo sidecar-verify")
PY

if [[ ${restart_service} -eq 1 ]]; then
  echo
  echo "Service action:"
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl daemon-reload
    if systemctl is-active --quiet "${MIHOMO_SERVICE_NAME}" 2>/dev/null; then
      sudo systemctl restart "${MIHOMO_SERVICE_NAME}"
      echo "  restarted ${MIHOMO_SERVICE_NAME}"
    else
      sudo systemctl start "${MIHOMO_SERVICE_NAME}"
      echo "  started ${MIHOMO_SERVICE_NAME}"
    fi
  else
    echo "  systemctl not found; skipped restart" >&2
  fi
fi

#!/bin/bash
set -euo pipefail

if [[ $# -gt 0 && ( "$1" == "-h" || "$1" == "--help" ) ]]; then
  cat <<'EOF'
usage: sidecar-status

Show current sidecar runtime parameters.
EOF
  exit 0
fi

BIN_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
SIDECAR_ROOT=$(cd -- "${BIN_DIR}/.." && pwd -P)
export MIHOMO_HOME="${MIHOMO_HOME:-${SIDECAR_ROOT}}"
export MIHOMO_SIDECAR_CONFIG="${MIHOMO_SIDECAR_CONFIG:-${SIDECAR_ROOT}/sidecar.env}"
if [[ -f "${BIN_DIR}/../script/common.sh" ]]; then
  # shellcheck disable=SC1091
  source "${BIN_DIR}/../script/common.sh"
elif [[ -f "${BIN_DIR}/../common.sh" ]]; then
  # shellcheck disable=SC1091
  source "${BIN_DIR}/../common.sh"
else
  echo "common.sh not found" >&2
  exit 1
fi

sidecar_load_config

echo "Sidecar status"
echo
echo "Runtime:"
echo "  work dir            ${MIHOMO_HOME}"
echo "  service             ${MIHOMO_SERVICE_NAME}"
echo "  sidecar group       ${MIHOMO_SIDECAR_GROUP}"
echo "  target gid          ${MIHOMO_TARGET_GID}"
echo "  transparent mode    ${MIHOMO_TRANSPARENT_ENABLED}"
echo "  transparent uids    ${MIHOMO_TRANSPARENT_UIDS:-<none>}"
echo
echo "Network:"
echo "  tun device          ${MIHOMO_TUN_DEV}"
echo "  controller          ${MIHOMO_API_HOST}:${MIHOMO_API_PORT}"
echo "  dns port            ${MIHOMO_DNS_PORT}"

if [[ -x "${MIHOMO_NODE_SCRIPT}" ]]; then
  current_node=$(python3 "${MIHOMO_NODE_SCRIPT}" --current 2>/dev/null || true)
  if [[ -n "${current_node}" ]]; then
    echo
    echo "Node:"
    printf '  %s\n' "${current_node}"
  fi
fi

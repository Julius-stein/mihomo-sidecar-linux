# Example shell snippet for mihomo-sidecar-linux
# Do not store real secrets in this file. Copy the lines you need into ~/.bashrc or ~/.zshrc.

export MIHOMO_HOME="${HOME}/.mihomo"
export MIHOMO_API_SECRET="<REPLACE_WITH_MIHOMO_CONTROLLER_SECRET>"

alias sidecar-node='python "$MIHOMO_HOME/select_node.py"'
alias sidecar-restart='sudo systemctl restart mihomo-sidecar.service'
alias sidecar-start='sudo systemctl start mihomo-sidecar.service'
alias sidecar-stop='sudo systemctl stop mihomo-sidecar.service'
alias sidecar-status='sudo systemctl status mihomo-sidecar.service --no-pager'
alias sidecar-log='sudo journalctl -u mihomo-sidecar.service -f'

sidecar() {
  local cmd
  printf -v cmd '%q ' "$@"
  sg sidecar -c "bash -lc $cmd"
}
